{
    "name": "Owner drains all funds (EGLD, ESDT, NFT) from forwarder blind",
    "steps": [
        {
            "step": "setState",
            "accounts": {
                "address:owner": {
                    "nonce": "0",
                    "balance": "0"
                },
                "sc:forwarder": {
                    "nonce": "0",
                    "balance": "1000",
                    "esdt": {
                        "str:TEST-TOKENA": "1000",
                        "str:NFT-COLLEC": {
                            "instances": [
                                {
                                    "nonce": "1",
                                    "balance": "5"
                                }
                            ]
                        }
                    },
                    "owner": "address:owner",
                    "code": "mxsc:../forwarder-blind/output/forwarder-blind.mxsc.json"
                }
            }
        },
        {
            "step": "scCall",
            "id": "drain EGLD",
            "tx": {
                "from": "address:owner",
                "to": "sc:forwarder",
                "function": "drain",
                "arguments": [
                    "str:EGLD-000000",
                    "0"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": [],
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "drain ESDT",
            "tx": {
                "from": "address:owner",
                "to": "sc:forwarder",
                "function": "drain",
                "arguments": [
                    "str:TEST-TOKENA",
                    "0"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": [],
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "scCall",
            "id": "drain NFT",
            "tx": {
                "from": "address:owner",
                "to": "sc:forwarder",
                "function": "drain",
                "arguments": [
                    "str:NFT-COLLEC",
                    "1"
                ],
                "gasLimit": "10,000,000",
                "gasPrice": "0"
            },
            "expect": {
                "out": [],
                "status": "0",
                "gas": "*",
                "refund": "*"
            }
        },
        {
            "step": "checkState",
            "accounts": {
                "address:owner": {
                    "nonce": "*",
                    "balance": "1000",
                    "esdt": {
                        "str:TEST-TOKENA": "1000",
                        "str:NFT-COLLEC": {
                            "instances": [
                                {
                                    "nonce": "1",
                                    "balance": "5"
                                }
                            ]
                        }
                    }
                },
                "sc:forwarder": {
                    "nonce": "0",
                    "balance": "0",
                    "esdt": {
                        "str:TEST-TOKENA": "0",
                        "str:NFT-COLLEC": {
                            "instances": [
                                {
                                    "nonce": "1",
                                    "balance": "0"
                                }
                            ]
                        }
                    },
                    "storage": {},
                    "code": "mxsc:../forwarder-blind/output/forwarder-blind.mxsc.json"
                }
            }
        }
    ]
}
